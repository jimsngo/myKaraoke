# --- Ignore EVERYTHING by default ---
/*
!/.gitignore

# --- Whitelist: Only allow specific folders and file types ---
!/tools/
!/tools/**/
!*.sh
!*.py
!*.json

# --- Explicitly ignore the heavy stuff in whitelisted folders ---
.venv/
__pycache__/
*.pyc
.DS_Store
backups_old/
*.mp3
*.wav
*.mp4
*.mov
*.mkv
*.heic
*.png
*.jpg
*.jpeg
*.aiff